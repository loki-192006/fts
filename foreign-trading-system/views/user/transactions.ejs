<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <%- include('../partials/sidebar', { activePage: 'Transactions' }) %>
  <div class="main-content">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px">
        <button class="notification-btn" id="sidebar-toggle"><i class="fas fa-bars"></i></button>
        <span class="topbar-title">Transaction History</span>
      </div>
      <div class="topbar-right">
        <a href="/trade" class="btn btn-primary btn-sm"><i class="fas fa-plus"></i> New Trade</a>
      </div>
    </div>
    <div class="page-content">
      <%- include('../partials/flash') %>
      <div class="page-header">
        <h1>Transaction History</h1>
        <p>Complete record of all your trades</p>
      </div>

      <!-- Filters -->
      <form method="GET" action="/dashboard/transactions">
        <div class="filters-bar">
          <div style="font-size:0.78rem;color:var(--text-muted);font-weight:600;padding:9px 0">Filter by:</div>
          <select name="type" class="filter-select" onchange="this.form.submit()">
            <option value="">All Types</option>
            <option value="buy" <%= filters.type === 'buy' ? 'selected' : '' %>>Buy Orders</option>
            <option value="sell" <%= filters.type === 'sell' ? 'selected' : '' %>>Sell Orders</option>
          </select>
          <input type="text" name="currency" class="filter-select" placeholder="Currency (e.g. EUR)" value="<%= filters.currency || '' %>" style="width:160px">
          <button type="submit" class="btn btn-outline btn-sm"><i class="fas fa-search"></i> Filter</button>
          <a href="/dashboard/transactions" class="btn btn-ghost btn-sm"><i class="fas fa-times"></i> Clear</a>
          <div style="margin-left:auto;font-size:0.78rem;color:var(--text-muted)"><%= total %> total records</div>
        </div>
      </form>

      <div class="card">
        <div class="table-wrap">
          <% if (transactions.length === 0) { %>
            <div class="empty-state">
              <i class="fas fa-search"></i>
              <p>No transactions found matching your filters</p>
            </div>
          <% } else { %>
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>Type</th>
                <th>Currency Pair</th>
                <th>Amount</th>
                <th>Exchange Rate</th>
                <th>Total Value</th>
                <th>Status</th>
                <th>Date & Time</th>
                <th>Receipt</th>
              </tr>
            </thead>
            <tbody>
              <% transactions.forEach((tx, index) => { %>
              <tr>
                <td style="color:var(--text-muted);font-size:0.78rem"><%= ((page-1)*limit)+index+1 %></td>
                <td><span class="type-badge <%= tx.type %>"><i class="fas fa-<%= tx.type === 'buy' ? 'arrow-up' : 'arrow-down' %>"></i> <%= tx.type.toUpperCase() %></span></td>
                <td><span class="text-mono fw-700"><%= tx.baseCurrency %></span><span style="color:var(--text-muted);margin:0 4px">/</span><span class="text-mono fw-700 text-accent"><%= tx.targetCurrency %></span></td>
                <td class="text-mono"><%= tx.amount.toFixed(4) %></td>
                <td class="text-mono" style="color:var(--text-secondary)"><%= tx.exchangeRate.toFixed(6) %></td>
                <td class="text-mono fw-700"><%= tx.totalValue.toFixed(4) %></td>
                <td><span class="status-badge <%= tx.status %>"><%= tx.status %></span></td>
                <td style="font-size:0.78rem;color:var(--text-muted)">
                  <div><%= new Date(tx.createdAt).toLocaleDateString() %></div>
                  <div style="color:var(--text-muted);font-size:0.72rem"><%= new Date(tx.createdAt).toLocaleTimeString() %></div>
                </td>
                <td>
                  <button onclick="printReceipt('<%= tx._id %>','<%= tx.type %>','<%= tx.baseCurrency %>','<%= tx.targetCurrency %>','<%= tx.amount %>','<%= tx.exchangeRate %>','<%= tx.totalValue %>','<%= tx.createdAt %>')"
                    class="btn btn-outline btn-sm"><i class="fas fa-receipt"></i></button>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } %>
        </div>
      </div>

      <!-- Pagination -->
      <% const totalPages = Math.ceil(total / limit); %>
      <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (page > 1) { %><a href="?page=<%= page-1 %>&type=<%= filters.type||'' %>&currency=<%= filters.currency||'' %>" class="page-btn"><i class="fas fa-chevron-left"></i></a><% } %>
        <% for(let i = Math.max(1,page-2); i <= Math.min(totalPages,page+2); i++) { %>
          <a href="?page=<%= i %>&type=<%= filters.type||'' %>&currency=<%= filters.currency||'' %>" class="page-btn <%= i===page ? 'active' : '' %>"><%= i %></a>
        <% } %>
        <% if (page < totalPages) { %><a href="?page=<%= page+1 %>&type=<%= filters.type||'' %>&currency=<%= filters.currency||'' %>" class="page-btn"><i class="fas fa-chevron-right"></i></a><% } %>
        <span class="page-info">Page <%= page %> of <%= totalPages %></span>
      </div>
      <% } %>
    </div>
  </div>
</div>

<!-- Receipt Modal (hidden, print-only) -->
<div id="receipt-data" style="display:none"></div>

<script>
function printReceipt(id, type, base, target, amount, rate, total, date) {
  const win = window.open('', '_blank', 'width=400,height=500');
  win.document.write(`
    <html><head><title>Trade Receipt</title>
    <style>
      body { font-family: monospace; background:#050d1a; color:#f1f5f9; padding:32px; }
      h2 { color:#14b8a6; margin-bottom:20px; }
      .row { display:flex; justify-content:space-between; padding:10px 0; border-bottom:1px solid #1e293b; }
      .label { color:#64748b; }
      .val { font-weight:700; }
      .footer { margin-top:24px; text-align:center; color:#64748b; font-size:0.8em; }
    </style>
    </head><body>
    <h2>💹 ForexPro — Trade Receipt</h2>
    <div class="row"><span class="label">Transaction ID</span><span class="val">${id.toString().slice(-8).toUpperCase()}</span></div>
    <div class="row"><span class="label">Order Type</span><span class="val" style="color:${type==='buy'?'#22c55e':'#ef4444'}">${type.toUpperCase()}</span></div>
    <div class="row"><span class="label">Currency Pair</span><span class="val">${base} / ${target}</span></div>
    <div class="row"><span class="label">Amount</span><span class="val">${parseFloat(amount).toFixed(4)} ${base}</span></div>
    <div class="row"><span class="label">Exchange Rate</span><span class="val">${parseFloat(rate).toFixed(6)}</span></div>
    <div class="row"><span class="label">Total Value</span><span class="val">${parseFloat(total).toFixed(4)} ${target}</span></div>
    <div class="row"><span class="label">Date & Time</span><span class="val">${new Date(date).toLocaleString()}</span></div>
    <div class="row"><span class="label">Status</span><span class="val" style="color:#22c55e">COMPLETED ✓</span></div>
    <div class="footer">ForexPro Foreign Trading System<br>This is an auto-generated receipt</div>
    <script>window.print();<\/script>
    </body></html>
  `);
}
</script>
<script src="/js/main.js"></script>
</body>
</html>
