<footer class="footer" id="contact">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="nav-brand"><i class="fas fa-chart-line logo-icon"></i><span>ForexPro</span></div>
        <p>A professional foreign currency trading platform built for modern traders. Secure, fast, and intuitive.</p>
      </div>
      <div class="footer-col">
        <h4>Platform</h4>
        <a href="/auth/register">Register</a>
        <a href="/auth/login">Login</a>
        <a href="#features">Features</a>
