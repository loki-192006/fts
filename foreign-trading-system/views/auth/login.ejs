<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body>
<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <i class="fas fa-chart-line logo-icon"></i>
      <span class="logo-name">ForexPro</span>
    </div>
    <%- include('../partials/flash') %>
    <h1 class="auth-title">Welcome Back</h1>
    <p class="auth-subtitle">Sign in to your trading account</p>
    <form action="/auth/login" method="POST">
      <div class="form-group">
        <label class="form-label">Email Address</label>
        <input type="email" name="email" class="form-control" placeholder="you@example.com" required>
      </div>
      <div class="form-group">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" placeholder="••••••••" required>
      </div>
      <button type="submit" class="btn btn-primary w-full" style="justify-content:center;padding:14px">
        <i class="fas fa-sign-in-alt"></i> Login to Dashboard
      </button>
    </form>
    <div style="margin-top:20px;padding:14px;background:rgba(20,184,166,0.06);border:1px solid var(--border);border-radius:var(--radius-sm)">
      <p style="font-size:0.75rem;color:var(--text-muted);margin-bottom:8px;font-weight:600;text-transform:uppercase;letter-spacing:1px">Demo Credentials</p>
      <p style="font-size:0.8rem;color:var(--text-secondary)">User: <span class="text-accent text-mono">arjun@example.com</span> / <span class="text-accent text-mono">user123</span></p>
      <p style="font-size:0.8rem;color:var(--text-secondary);margin-top:4px">Admin: <span class="text-accent text-mono">admin@forexpro.com</span> / <span class="text-accent text-mono">admin123</span></p>
    </div>
    <div class="auth-footer-link">Don't have an account? <a href="/auth/register">Create one</a></div>
    <div style="text-align:center;margin-top:16px"><a href="/" style="color:var(--text-muted);font-size:0.82rem"><i class="fas fa-arrow-left"></i> Back to Home</a></div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
