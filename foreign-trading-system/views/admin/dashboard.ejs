<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
</head>
<body>
<div class="app-layout">
  <%- include('../partials/adminSidebar', { activePage: 'Dashboard' }) %>
  <div class="main-content">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px">
        <button class="notification-btn" id="sidebar-toggle"><i class="fas fa-bars"></i></button>
        <span class="topbar-title">Admin Dashboard</span>
      </div>
      <div class="topbar-right">
        <span class="admin-badge"><i class="fas fa-shield-alt"></i> Admin Panel</span>
        <a href="/auth/logout" class="btn btn-danger btn-sm"><i class="fas fa-sign-out-alt"></i> Logout</a>
      </div>
    </div>
    <div class="page-content">
      <%- include('../partials/flash') %>
      <div class="page-header">
        <h1>Platform Overview</h1>
        <p>Monitor and manage the ForexPro trading platform</p>
      </div>

      <!-- Admin Stats -->
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-card-glow"></div>
          <div class="stat-icon"><i class="fas fa-users"></i></div>
          <div class="stat-label">Total Users</div>
          <div class="stat-value" data-counter="<%= totalUsers %>"><%= totalUsers %></div>
          <div class="stat-sub">Registered traders</div>
        </div>
        <div class="stat-card green">
          <div class="stat-card-glow"></div>
          <div class="stat-icon"><i class="fas fa-exchange-alt"></i></div>
          <div class="stat-label">Total Trades</div>
          <div class="stat-value" data-counter="<%= totalTrades %>"><%= totalTrades %></div>
          <div class="stat-sub">All time executions</div>
        </div>
        <div class="stat-card blue">
          <div class="stat-card-glow"></div>
          <div class="stat-icon"><i class="fas fa-coins"></i></div>
          <div class="stat-label">Active Currencies</div>
          <div class="stat-value"><%= rates.length %></div>
          <div class="stat-sub">Tradeable pairs</div>
        </div>
        <div class="stat-card">
          <div class="stat-card-glow"></div>
          <div class="stat-icon" style="background:rgba(245,158,11,0.1);color:var(--yellow)"><i class="fas fa-chart-bar"></i></div>
          <div class="stat-label">Trading Volume</div>
          <div class="stat-value">$<%= totalVolume %></div>
          <div class="stat-sub">Total platform volume</div>
        </div>
      </div>

      <div style="display:grid;grid-template-columns:2fr 1fr;gap:24px;margin-bottom:24px">
        <!-- Recent Transactions -->
        <div class="card">
          <div class="card-header">
            <div class="card-title">Recent Transactions</div>
            <a href="/admin/transactions" style="font-size:0.8rem;color:var(--accent)">View All →</a>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr><th>User</th><th>Type</th><th>Pair</th><th>Value</th><th>Date</th><th>Status</th></tr>
              </thead>
              <tbody>
                <% recentTrades.forEach(tx => { %>
                <tr>
                  <td style="font-size:0.82rem;font-weight:600"><%= tx.userId ? tx.userId.name : 'Unknown' %></td>
                  <td><span class="type-badge <%= tx.type %>"><%= tx.type.toUpperCase() %></span></td>
                  <td class="text-mono" style="font-size:0.82rem"><%= tx.baseCurrency %>/<%= tx.targetCurrency %></td>
                  <td class="text-mono fw-700" style="font-size:0.82rem">$<%= tx.totalValue.toFixed(2) %></td>
                  <td style="font-size:0.72rem;color:var(--text-muted)"><%= new Date(tx.createdAt).toLocaleDateString() %></td>
                  <td><span class="status-badge <%= tx.status %>"><%= tx.status %></span></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>

        <!-- Recent Users + Rates Mini -->
        <div style="display:flex;flex-direction:column;gap:20px">
          <div class="card">
            <div class="card-header">
              <div class="card-title">New Users</div>
              <a href="/admin/users" style="font-size:0.8rem;color:var(--accent)">View All →</a>
            </div>
            <div class="card-body" style="padding:0">
              <% recentUsers.forEach(u => { %>
              <div style="display:flex;align-items:center;gap:12px;padding:12px 20px;border-bottom:1px solid var(--border-subtle)">
                <div class="user-avatar" style="width:32px;height:32px;font-size:0.75rem"><%= u.name.charAt(0).toUpperCase() %></div>
                <div style="flex:1;min-width:0">
                  <div style="font-size:0.82rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= u.name %></div>
                  <div style="font-size:0.7rem;color:var(--text-muted)">$<%= u.walletBalance.toFixed(0) %> balance</div>
                </div>
                <span style="font-size:0.7rem;color:<%= u.isActive ? 'var(--green)' : 'var(--red)' %>">● <%= u.isActive ? 'Active' : 'Inactive' %></span>
              </div>
              <% }) %>
            </div>
          </div>

          <div class="card">
            <div class="card-header"><div class="card-title">Top Rates</div><a href="/admin/rates" style="font-size:0.8rem;color:var(--accent)">Manage →</a></div>
            <div class="card-body" style="padding:0">
              <% rates.slice(0,5).forEach(r => { %>
              <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 20px;border-bottom:1px solid var(--border-subtle)">
                <span style="font-weight:700;font-size:0.85rem"><%= r.currencyCode %></span>
                <span class="text-mono" style="font-size:0.82rem"><%= r.rateToUSD.toFixed(4) %></span>
                <span style="font-size:0.72rem;font-weight:600;color:<%= r.change24h >= 0 ? 'var(--green)' : 'var(--red)' %>"><%= r.change24h >= 0 ? '+' : '' %><%= r.change24h %>%</span>
              </div>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Admin Actions -->
      <div class="card">
        <div class="card-header"><div class="card-title">Quick Actions</div></div>
        <div class="card-body">
          <div style="display:flex;gap:14px;flex-wrap:wrap">
            <a href="/admin/users" class="btn btn-outline"><i class="fas fa-users"></i> Manage Users</a>
            <a href="/admin/transactions" class="btn btn-outline"><i class="fas fa-list"></i> All Transactions</a>
            <a href="/admin/rates" class="btn btn-outline"><i class="fas fa-chart-line"></i> Update Rates</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
