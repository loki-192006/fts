<!DOCTYPE html>
<html lang="en">
<head><%- include('../partials/head') %></head>
<body>
<div class="app-layout">
  <%- include('../partials/adminSidebar', { activePage: 'Transactions' }) %>
  <div class="main-content">
    <div class="topbar">
      <div style="display:flex;align-items:center;gap:12px">
        <button class="notification-btn" id="sidebar-toggle"><i class="fas fa-bars"></i></button>
        <span class="topbar-title">All Transactions</span>
      </div>
      <div class="topbar-right">
        <span class="admin-badge"><i class="fas fa-shield-alt"></i> Admin</span>
      </div>
    </div>
    <div class="page-content">
      <%- include('../partials/flash') %>
      <div class="page-header">
        <h1>All Platform Transactions</h1>
        <p>Monitor every trade executed on ForexPro (<%= transactions.length %> records)</p>
      </div>
      <div class="card">
        <div class="table-wrap">
          <% if (transactions.length === 0) { %>
            <div class="empty-state"><i class="fas fa-exchange-alt"></i><p>No transactions yet</p></div>
          <% } else { %>
          <table>
            <thead>
              <tr><th>#</th><th>User</th><th>Type</th><th>Pair</th><th>Amount</th><th>Rate</th><th>Value</th><th>Status</th><th>Date</th></tr>
            </thead>
            <tbody>
              <% transactions.forEach((tx, i) => { %>
              <tr>
                <td style="color:var(--text-muted);font-size:0.75rem"><%= i+1 %></td>
                <td>
                  <div style="font-size:0.82rem;font-weight:600"><%= tx.userId ? tx.userId.name : 'Deleted User' %></div>
                  <div style="font-size:0.7rem;color:var(--text-muted)"><%= tx.userId ? tx.userId.email : '' %></div>
                </td>
                <td><span class="type-badge <%= tx.type %>"><%= tx.type.toUpperCase() %></span></td>
                <td class="text-mono fw-700" style="font-size:0.85rem"><%= tx.baseCurrency %>/<%= tx.targetCurrency %></td>
                <td class="text-mono" style="font-size:0.82rem"><%= tx.amount.toFixed(2) %></td>
                <td class="text-mono" style="font-size:0.78rem;color:var(--text-secondary)"><%= tx.exchangeRate.toFixed(4) %></td>
                <td class="text-mono fw-700 text-accent" style="font-size:0.85rem"><%= tx.totalValue.toFixed(2) %></td>
                <td><span class="status-badge <%= tx.status %>"><%= tx.status %></span></td>
                <td style="font-size:0.72rem;color:var(--text-muted)"><%= new Date(tx.createdAt).toLocaleDateString() %></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
