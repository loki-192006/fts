<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
<div class="error-page">
  <div>
    <div class="error-code">404</div>
    <h1 class="error-title">Page Not Found</h1>
    <p class="error-desc">The page you're looking for doesn't exist or has been moved.</p>
    <div style="display:flex;gap:12px;justify-content:center">
      <% if (currentUser) { %>
        <a href="<%= currentUser.role === 'admin' ? '/admin/dashboard' : '/dashboard' %>" class="btn btn-primary"><i class="fas fa-home"></i> Go to Dashboard</a>
      <% } else { %>
        <a href="/" class="btn btn-primary"><i class="fas fa-home"></i> Go Home</a>
        <a href="/auth/login" class="btn btn-outline"><i class="fas fa-sign-in-alt"></i> Login</a>
      <% } %>
    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
